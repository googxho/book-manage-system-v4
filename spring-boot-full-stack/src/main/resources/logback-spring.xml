<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ================================================================ -->
    <!--  ① 引入 Spring Boot 的默认日志配置                              -->
    <!-- ================================================================ -->
    <!--
      这行代码的作用：把 Spring Boot 内置的 defaults.xml 文件导入到当前配置中。
      
      defaults.xml 里面有什么？
      ├─ CONSOLE_LOG_CHARSET（控制台字符编码，默认 UTF-8）
      ├─ FILE_LOG_CHARSET（文件字符编码，默认 UTF-8）
      ├─ LOG_DATEFORMAT_PATTERN（日期格式，默认 yyyy-MM-dd HH:mm:ss.SSS）
      ├─ LOG_LEVEL_PATTERN（日志级别格式，默认 %5p）
      └─ 其他几个 Logback 标准默认值
      
      这些默认值被定义好后，下面就可以用 ${变量名} 来引用它们。
      比如 ${CONSOLE_LOG_CHARSET} 就是 "UTF-8"。
      
      如果你不 include 这个文件，也可以手动定义这些属性，但 Spring Boot
      推荐 include 它省事。
    -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />


    <!-- ================================================================ -->
    <!--  ② 定义日志输出格式（Layout / Pattern）                         -->
    <!-- ================================================================ -->
    <!--
      这是整个配置里最关键也最难懂的部分。下面逐个拆解每个占位符的含义。
      
      ★ 控制台日志格式（带颜色）：
    -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%clr(%d{${LOG_DATEFORMAT_PATTERN:-yyyy-MM-dd HH:mm:ss.SSS}}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p})  %clr([%15.15t]){faint} %clr(\(%X{reqId:-system}\)){faint} %clr(--){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

    <!--
      ★ 文件日志格式（不带颜色，纯文本）：
    -->
    <property name="FILE_LOG_PATTERN"
              value="%d{${LOG_DATEFORMAT_PATTERN:-yyyy-MM-dd HH:mm:ss.SSS}} ${LOG_LEVEL_PATTERN:-%5p} ${PID:- } --- [%t] \(%X{reqId:-system}\) %-40.40logger{39} : %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

    <!--
      ═══════════════════════════════════════════════════════════════════
      
      占位符详细对照表（以下每个 %X 都是一个"占位符"，运行时会替换成实际值）：
      
      ═══ 时间 ═══
      %d{${LOG_DATEFORMAT_PATTERN:-yyyy-MM-dd HH:mm:ss.SSS}}
        ├─ %d{...}      → date（日期），按指定格式输出时间
        ├─ ${...}       → 引用 defaults.xml 里定义的变量
        └─ :-后面的内容  → 如果变量未定义就用这个默认值
        输出示例：2026-06-27 14:30:22.123
      
      ═══ 日志级别 ═══
      ${LOG_LEVEL_PATTERN:-%5p}
        ├─ %5p          → priority（优先级/级别），右对齐占5个字符
        └─ 输出示例：" INFO"（前面1个空格，右对齐）
      
      ═══ 线程信息 ═══
      [%15.15t]
        ├─ %t           → thread（线程名）
        ├─ 15.15        → 最少15个字符，最多15个字符（截断对齐）
        └─ 输出示例："[       main]" 或 "[http-nio-8080-]"
      
      ═══ 请求追踪ID ═══
      %X{reqId:-system}
        ├─ %X{...}      → MDC（Mapped Diagnostic Context）中取的值
        ├─ reqId        → 键名，对应 MDC 中存入的请求追踪 ID
        └─ :-system     → 如果没有这个值（没设 MDC），显示 "system"
        输出示例：(abc-123-def) 或 (system)
      
      ═══ Logger名称 ═══
      %-40.40logger{39}
        ├─ %logger{39}  → Logger 名称，只保留最后 39 个字符
        ├─ -40.40       → 左对齐(-)，最少40字符，最多40字符
        └─ 输出示例：c.e.s.impl.AccountServiceImpl
      
      ═══ 日志消息 ═══
      %m
        ├─ m            → message（实际日志内容）
        └─ 就是你代码里 log.info("xxx") 的那个 "xxx"
      
      ═══ 换行 ═══
      %n
        ├─ n            → newline（换行符）
        └─ Windows=\r\n，Linux/Mac=\n
      
      ═══ 颜色（仅控制台） ═══
      %clr(...){faint}
        ├─ %clr         → color（上色）
        ├─ {faint}      → 颜色样式：faint=淡色，cyan=青色，默认按级别上色
        ├─ 不同日志级别自动上不同颜色：
        │  TRACE → 灰色    DEBUG → 绿色    INFO → 蓝色
        │  WARN  → 黄色    ERROR → 红色
        └─ 文件日志不用 %clr，因为日志文件里存 ANSI 颜色码会造成乱码
      
      ═══ 进程ID ═══
      ${PID:- }
        ├─ ${PID}       → Process ID（操作系统进程号）
        ├─ :-           → 后面跟默认值（空格）
        └─ 这个只在文件日志里用了，控制台有颜色不需要
      
      ═══════════════════════════════════════════════════════════════════
      
      整条日志组装起来的效果：
      
      控制台（彩色）：
        2026-06-27 14:30:22.123  INFO  [main]  (reqId) — c.e.s.impl.AccountServiceImpl : 用户登录成功
      
      文件（纯文本）：
        2026-06-27 14:30:22.123  INFO 12345 — [main] (reqId) c.e.s.impl.AccountServiceImpl : 用户登录成功
      
      拆分对应关系：
        %d{...}     → 2026-06-27 14:30:22.123
        %5p         →   INFO（注意前面有空格）
        [%15.15t]   → [main]
        %X{reqId}   → (abc123)
        %logger{39} → c.e.s.impl.AccountServiceImpl
        %m          → 用户登录成功
    -->


    <!-- ================================================================ -->
    <!--  ③ Appender（输出目的地）— 控制台                              -->
    <!-- ================================================================ -->
    <!--
      ConsoleAppender：把日志输出到终端命令行。
      
      在 IntelliJ IDEA 里 → 显示在 Run 面板
      在 VS Code 里      → 显示在 TERMINAL 面板
      在服务器上         → 显示在 ssh 终端窗口
      
      你启动项目后，在终端里看到的所有日志都是这个 Appender 输出的。
    -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- 使用上面定义的控制台格式（带颜色） -->
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <!-- 字符编码，从 defaults.xml 继承，默认 UTF-8 -->
            <charset>${CONSOLE_LOG_CHARSET}</charset>
        </encoder>
    </appender>


    <!-- ================================================================ -->
    <!--  ④ Appender（输出目的地）— 文件（按日期/大小滚动）            -->
    <!-- ================================================================ -->
    <!--
      RollingFileAppender：把日志写入磁盘文件。
      
      与普通 FileAppender 的区别：
      普通 FileAppender → 从启动写到关闭，所有日志塞进同一个文件
      RollingFileAppender → 自动切分文件（按天/按大小），防止单个文件过大
      
      如果你的项目运行半年不重启，普通 FileAppender 会产生一个 10GB 的日志文件，
      编辑器打不开、搜索搜不了。RollingFileAppender 每天生成一个新文件，
      每个文件最多 10MB，超过就自动编号（-0, -1, -2...），7天前的自动删除。
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <encoder>
            <!-- 使用上面定义的文件格式（纯文本，不带颜色） -->
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <!-- 字符编码，从 defaults.xml 继承，默认 UTF-8 -->
            <charset>${FILE_LOG_CHARSET}</charset>
        </encoder>

        <!--
          ═══ 滚动策略（核心中的核心） ═══
          
          SizeAndTimeBasedRollingPolicy = 按时间 + 按大小双重切分。
          
          翻译成人话就是：
          1. 每天生成一个新日志文件（按时间切分）
          2. 同一天内如果日志超过了 10MB，自动编号 -0, -1, -2...（按大小切分）
          3. 只保留最近 7 天的日志（超期自动删除）
          4. 下次启动时检查一次，把过期的一次性清理掉
        -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">

            <!--
              ★ FileNamePattern — 日志文件的命名规则
              
              log/                          → 放在项目根目录的 log 文件夹里
              %d{yyyy-MM-dd}                → 日期，每天一个文件夹/文件名
              spring                        → 固定前缀，方便区分不同应用的日志
              %i                            → 同一天内的文件序号（从 0 开始）
              .log                          → 文件扩展名
              
              实际生成的文件名示例：
                log/2026-06-27-spring-0.log   ← 今天第1个文件（刚启动/未满10MB）
                log/2026-06-27-spring-1.log   ← 今天第2个文件（第1个写满10MB了）
                log/2026-06-27-spring-2.log   ← 第3个
                log/2026-06-26-spring-0.log   ← 昨天的日志
                log/2026-06-25-spring-0.log   ← 前天的...
            -->
            <FileNamePattern>log/%d{yyyy-MM-dd}-spring-%i.log</FileNamePattern>

            <!--
              cleanHistoryOnStart：启动时是否清理过期文件。
              true → 项目每次启动都会检查并删除过期日志
              false → 只在滚动时清理（如果项目很久不重启，过期文件不会被删）
              建议 true，因为线上部署经常发布重启，能及时清理磁盘空间。
            -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>

            <!--
              maxHistory：最多保留多少天的日志。
              7 → 只保留最近 7 天的日志文件，第 8 天及以前的自动删除。
              
              怎么算的？
              今天是 6月27日，maxHistory=7，那么：
              保留：6月21日 ~ 6月27日（7天）
              删除：6月20日及更早
              
              如果你用磁盘监控，1天的日志约 30-100MB（取决于请求量），
              保留 7 天约 210MB-700MB，普通服务器完全扛得住。
            -->
            <maxHistory>7</maxHistory>

            <!--
              maxFileSize：单个日志文件的最大体积。
              10MB → 每个日志文件最多写 10MB，超过了就新建一个编号 +1 的文件。
              
              为什么要限制单个文件大小？
              - 10MB 的文本文件用 VSCode/Notepad++ 打开不卡
              - 100MB 的文本文件打开要等好几秒，搜个关键词要等更久
              - 1GB 的文本文件基本打不开了
            -->
            <maxFileSize>10MB</maxFileSize>
        </rollingPolicy>
    </appender>


    <!-- ================================================================ -->
    <!--  ⑤ Root Logger（根日志记录器）— 全局入口                      -->
    <!-- ================================================================ -->
    <!--
      ★ root 是整个日志系统的"总管"。
      
      所有 Logger 都是 root 的子节点（包括你的代码里的 log.info(...)），
      如果某个类没有单独配置 Logger，就完全继承 root 的设置。
      
      level="INFO"：
        只输出 INFO 及以上级别的日志（INFO / WARN / ERROR）。
        TRACE 和 DEBUG 级别的一律丢弃。
        
        常见的 level 设置：
          level="TRACE"  → 输出所有日志（最详细，生产环境不要用，会刷爆磁盘）
          level="DEBUG"  → 输出 DEBUG 及以上（开发调试用）
          level="INFO"   → 输出 INFO 及以上（推荐生产环境使用）
          level="WARN"   → 只输出 WARN 和 ERROR（安静模式）
          level="ERROR"  → 只输出 ERROR（几乎不说话）
          level="OFF"    → 完全关闭日志（基本不用）
      
      ★ 关于级别过滤的逻辑（面试常考）：
      
        当代码执行 log.info("xxx") 时：
        
        ① Logger 收到 "级别=INFO，消息=xxx"
        ② Logger 查看自己的配置级别（这里 root 配了 INFO）
        ③ 判断：INFO >= INFO → 通过 ✅ → 交给 Appender
          如果代码里写的是 log.debug("xxx")：
          判断：DEBUG < INFO → 不通过 ❌ → 直接丢弃
        
        所以日志级别是"单向过滤"的：
          配置为 INFO  → 只看 INFO 及以上
          配置为 WARN  → 只看 WARN 及以上
          级别越高，内容越少
      
      appender-ref：
        把 Console 和 FILE 两个 Appender 绑定到 root Logger 上。
        意思是所有通过级别过滤的日志，同时输出到控制台和文件。
        
        如果你只想写文件、不打印到控制台，就删掉 CONSOLE 那行。
    -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>


    <!-- ================================================================ -->
    <!--                                                                 
    │                                                                      │
    │          ╔══════════════════════════════════════════════════╗        │
    │          ║                                                  ║        │
    │          ║      Logback 日志系统 — 完整技术架构说明书        ║        │
    │          ║                                                  ║        │
    │          ╚══════════════════════════════════════════════════╝        │
    │                                                                      │
    │  下面回答你提到的所有问题：                                          │
    │  ├─ 日志是谁打印的？                                                │
    │  ├─ 它怎么知道要打印这些信息？                                      │
    │  ├─ 这些信息是从哪里获取的？                                        │

    ║                                                                  ║
    ║  五、完整的技术架构图（从代码到磁盘的全链路）                    ║
    ║                                                                  ║
    ╚══════════════════════════════════════════════════════════════════╝

    ┌─────────────────────────────────────────────────────────────────────┐
    │                                                                     │
    │  ① 你的 Java 代码                                                   │
    │                                                                     │
    │     @Slf4j → log.info("用户 {} 登录", name);                        │
    │       │                                                             │
    │       │ 编译时 Lombok 展开为：                                       │
    │       │ LoggerFactory.getLogger(AccountServiceImpl.class)           │
    │       ▼                                                             │
    │                                                                     │
    │  ② SLF4J 门面层（接口，不干活）                                     │
    │                                                                     │
    │     org.slf4j.Logger 接口                                           │
    │       ├─ .info(String msg, Object... args)                          │
    │       ├─ .warn(String msg, Object... args)                          │
    │       ├─ .error(String msg, Object... args)                         │
    │       └─ .debug(...) / .trace(...)                                  │
    │       │                                                             │
    │       │ SLF4J 不做任何事，它只是"定义了一套日志方法签名"，           │
    │       │ 具体实现在启动时通过 ServiceLoader 机制自动发现并绑定。       │
    │       ▼                                                             │
    │                                                                     │
    │  ③ Logback 核心实现层（真正干活的）                                  │
    │                                                                     │
    │     ch.qos.logback.classic.Logger                                   │
    │       │  (继承 org.slf4j.Logger 接口)                                │
    │       │                                                             │
    │       ├── 第 1 步：判断级别                                          │
    │       │   ┌──────────────────────────────────────────┐              │
    │       │   │ Logger.effectiveLevel ≥ 请求级别?        │              │
    │       │   │ 例：effectiveLevel=INFO, 请求=INFO → ✅ │              │
    │       │   │      effectiveLevel=INFO, 请求=DEBUG → ❌│              │
    │       │   └──────────────────────────────────────────┘              │
    │       │      │                                                      │
    │       │      ▼ 通过                                                 │
    │       │                                                             │
    │       ├── 第 2 步：构造 LoggingEvent                                 │
    │       │   Logback 把"要打印的信息"打包成一个事件对象：                │
    │       │                                                             │
    │       │   LoggingEvent {                                           │
    │       │     level:        INFO          ← 从代码参数获取            │
    │       │     message:      "用户 {} 登录" ← 从代码参数获取            │
    │       │     args:         ["张三"]      ← 从代码参数获取            │
    │       │     formattedMsg: "用户 张三 登录" ← Logback 替换 {} 后的结果│
    │       │     threadName:   "main"        ← Thread.currentThread()   │
    │       │     loggerName:   "c.e.s.impl.AccountServiceImpl" ← 预存值 │
    │       │     timestamp:    1719474622123 ← System.currentTimeMillis()│
    │       │     mdcMap:       {reqId=xxx}   ← MDC.getCopyOfContextMap() │
    │       │     // ... 还有 callerData（行号）、throwable（异常）等     │
    │       │   }                                                         │
    │       │                                                             │
    │       │   ★ 关键：所有信息在这一步就已经全部收集好了！               │
    │       │     后面 Appender 只需要从这个事件对象里"读"就行了。         │
    │       │                                                             │
    │       │   ▼                                                         │
    │       │                                                             │
    │       ├── 第 3 步：调用 Appender                                    │
    │       │   把 LoggingEvent 传给所有绑定的 Appender。                  │
    │       │   ┌──────────────────────────────────────────┐              │
    │       │   │ <root level="INFO">                      │              │
    │       │   │   <appender-ref ref="CONSOLE"/>  ────────┤───┐         │
    │       │   │   <appender-ref ref="FILE"/>     ────────┤───┤──┐      │
    │       │   └──────────────────────────────────────────┘   │  │      │
    │       ▼                                                   ▼  ▼      │
    │                                                                     │
    │  ④ Appender 层（输出目的地）                                        │
    │                                                                     │
    │     ┌── ConsoleAppender ──────────────────────┐                     │
    │     │  ConsoleAppender.append(LoggingEvent e)  │                     │
    │     │    ↓                                     │                     │
    │     │  Encoder.encode(e)                       │                     │
    │     │    ↓                                     │                     │
    │     │  Layout.doLayout(e) → 拼装字符串         │                     │
    │     │    ↓                                     │                     │
    │     │  System.out.write(字符串.getBytes())     │                     │
    │     └──────────────────────────────────────────┘                     │
    │                                                                     │
    │     ┌── RollingFileAppender ───────────────────┐                     │
    │     │  RollingFileAppender.append(e)            │                     │
    │     │    ↓                                     │                     │
    │     │  Encoder.encode(e)                       │                     │
    │     │    ↓                                     │                     │
    │     │  Layout.doLayout(e) → 拼装字符串         │                     │
    │     │    ↓                                     │                     │
    │     │  判断：当前文件 > 10MB?                   │                     │
    │     │    ├─ 是 → 创建新文件（编号+1）           │                     │
    │     │    └─ 否 → 继续写入当前文件               │                     │
    │     │    ↓                                     │                     │
    │     │  FileOutputStream.write(字符串.getBytes())│                     │
    │     └──────────────────────────────────────────┘                     │
    │                                                                     │
    │  ⑤ Layout/Pattern 层（格式拼装）                                    │
    │                                                                     │
    │     PatternLayout.doLayout(LoggingEvent e) {                        │
    │       // 把 pattern 字符串里的 %d, %p, %t, %m 等占位符              │
    │       // 逐个替换成 LoggingEvent 对象里的实际值                     │
    │       return  "2026-06-27 14:30:22.123  INFO  [main]  " +          │
    │               "(reqId) — c.e.s.impl.AccountServiceImpl : " +      │
    │               "用户 张三 登录\n";                                   │
    │     }                                                               │
    │                                                                     │
    └─────────────────────────────────────────────────────────────────────┘
                                         │
                                         ▼
    ┌─────────────────────────────────────────────────────────────────────┐
    │  ⑥ 最终输出                                                        │
    │                                                                     │
    │     控制台：终端窗口里显示彩色日志                                   │
    │     文件：  log/2026-06-27-spring-0.log 里写入纯文本日志            │
    │                                                                     │
    └─────────────────────────────────────────────────────────────────────┘


